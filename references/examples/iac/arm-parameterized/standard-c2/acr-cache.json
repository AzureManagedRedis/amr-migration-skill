{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_scenario": "Parameterized Standard C2 — typical dev/test cache with no Premium features"
  },
  "parameters": {
    "redisCacheName": {
      "type": "string",
      "metadata": { "description": "Name of the Azure Cache for Redis instance." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region." }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": ["Basic", "Standard", "Premium"],
      "metadata": { "description": "Pricing tier." }
    },
    "skuFamily": {
      "type": "string",
      "defaultValue": "C",
      "allowedValues": ["C", "P"],
      "metadata": { "description": "SKU family." }
    },
    "skuCapacity": {
      "type": "int",
      "defaultValue": 2,
      "metadata": { "description": "Cache size (0-6 for C family)." }
    },
    "enableNonSslPort": {
      "type": "bool",
      "defaultValue": false,
      "metadata": { "description": "Enable the non-TLS port (6379)." }
    },
    "minimumTlsVersion": {
      "type": "string",
      "defaultValue": "1.2",
      "metadata": { "description": "Minimum TLS version." }
    },
    "redisVersion": {
      "type": "string",
      "defaultValue": "6",
      "metadata": { "description": "Redis server version." }
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": ["Enabled", "Disabled"],
      "metadata": { "description": "Public network access." }
    },
    "maxmemoryPolicy": {
      "type": "string",
      "defaultValue": "volatile-lru",
      "metadata": { "description": "Eviction policy." }
    },
    "aadEnabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": { "description": "Enable Entra ID authentication." }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": { "description": "Resource tags." }
    }
  },
  "variables": {
    "redisConfiguration": {
      "maxmemory-policy": "[parameters('maxmemoryPolicy')]",
      "aad-enabled": "[if(parameters('aadEnabled'), 'true', 'false')]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Cache/redis",
      "apiVersion": "2024-03-01",
      "name": "[parameters('redisCacheName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "enableNonSslPort": "[parameters('enableNonSslPort')]",
        "minimumTlsVersion": "[parameters('minimumTlsVersion')]",
        "redisVersion": "[parameters('redisVersion')]",
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "sku": {
          "name": "[parameters('skuName')]",
          "family": "[parameters('skuFamily')]",
          "capacity": "[parameters('skuCapacity')]"
        },
        "redisConfiguration": "[variables('redisConfiguration')]"
      }
    }
  ],
  "outputs": {
    "cacheId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/redis', parameters('redisCacheName'))]"
    },
    "cacheHostName": {
      "type": "string",
      "value": "[reference(parameters('redisCacheName')).hostName]"
    }
  }
}
