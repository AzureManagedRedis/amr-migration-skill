{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_scenario": "Parameterized Premium P2 — template + parameters file pair",
    "_sourceSkuInfo": "Premium P2 (13 GB), actual values come from parameters file"
  },
  "parameters": {
    "redisCacheName": {
      "type": "string",
      "metadata": { "description": "Name of the Azure Cache for Redis instance." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for the Redis cache." }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Premium",
      "allowedValues": ["Basic", "Standard", "Premium"],
      "metadata": { "description": "Pricing tier." }
    },
    "skuFamily": {
      "type": "string",
      "defaultValue": "P",
      "allowedValues": ["C", "P"],
      "metadata": { "description": "SKU family." }
    },
    "skuCapacity": {
      "type": "int",
      "defaultValue": 2,
      "metadata": { "description": "Cache size." }
    },
    "enableNonSslPort": {
      "type": "bool",
      "defaultValue": false,
      "metadata": { "description": "Enable the non-TLS port (6379)." }
    },
    "minimumTlsVersion": {
      "type": "string",
      "defaultValue": "1.2",
      "metadata": { "description": "Minimum TLS version." }
    },
    "redisVersion": {
      "type": "string",
      "defaultValue": "6",
      "metadata": { "description": "Redis server version." }
    },
    "publicNetworkAccess": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": ["Enabled", "Disabled"],
      "metadata": { "description": "Public network access." }
    },
    "shardCount": {
      "type": "int",
      "defaultValue": 0,
      "metadata": { "description": "Number of shards (0 = non-clustered)." }
    },
    "replicasPerPrimary": {
      "type": "int",
      "defaultValue": 1,
      "metadata": { "description": "Replicas per primary (Premium only)." }
    },
    "rdbBackupEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": { "description": "Enable RDB persistence." }
    },
    "rdbBackupFrequency": {
      "type": "int",
      "defaultValue": 60,
      "allowedValues": [15, 30, 60, 360, 720, 1440],
      "metadata": { "description": "RDB backup frequency in minutes." }
    },
    "rdbStorageConnectionString": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": { "description": "Storage account connection string for RDB persistence." }
    },
    "maxmemoryPolicy": {
      "type": "string",
      "defaultValue": "volatile-lru",
      "metadata": { "description": "Eviction policy." }
    },
    "maxmemoryReserved": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Memory reserved (MB) for non-cache operations." }
    },
    "maxfragmentationmemoryReserved": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Fragmentation memory reserved (MB)." }
    },
    "aadEnabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": { "description": "Enable Entra ID authentication." }
    },
    "firewallRules": {
      "type": "array",
      "defaultValue": [],
      "metadata": { "description": "Array of firewall rules: [{ name, startIP, endIP }]." }
    },
    "zones": {
      "type": "array",
      "defaultValue": [],
      "metadata": { "description": "Availability zones." }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": { "description": "Resource tags." }
    }
  },
  "variables": {
    "isPremium": "[equals(parameters('skuName'), 'Premium')]",
    "baseRedisConfig": {
      "maxmemory-policy": "[parameters('maxmemoryPolicy')]",
      "aad-enabled": "[if(parameters('aadEnabled'), 'true', 'false')]"
    },
    "reservedConfig": "[if(not(empty(parameters('maxmemoryReserved'))), createObject('maxmemory-reserved', parameters('maxmemoryReserved')), createObject())]",
    "fragConfig": "[if(not(empty(parameters('maxfragmentationmemoryReserved'))), createObject('maxfragmentationmemory-reserved', parameters('maxfragmentationmemoryReserved')), createObject())]",
    "rdbConfig": "[if(parameters('rdbBackupEnabled'), createObject('rdb-backup-enabled', 'true', 'rdb-backup-frequency', string(parameters('rdbBackupFrequency')), 'rdb-storage-connection-string', parameters('rdbStorageConnectionString')), createObject())]",
    "redisConfiguration": "[union(variables('baseRedisConfig'), variables('reservedConfig'), variables('fragConfig'), variables('rdbConfig'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Cache/redis",
      "apiVersion": "2024-03-01",
      "name": "[parameters('redisCacheName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "zones": "[if(and(variables('isPremium'), not(empty(parameters('zones')))), parameters('zones'), createArray())]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "enableNonSslPort": "[parameters('enableNonSslPort')]",
        "minimumTlsVersion": "[parameters('minimumTlsVersion')]",
        "redisVersion": "[parameters('redisVersion')]",
        "publicNetworkAccess": "[parameters('publicNetworkAccess')]",
        "sku": {
          "name": "[parameters('skuName')]",
          "family": "[parameters('skuFamily')]",
          "capacity": "[parameters('skuCapacity')]"
        },
        "redisConfiguration": "[variables('redisConfiguration')]",
        "shardCount": "[if(and(variables('isPremium'), greater(parameters('shardCount'), 0)), parameters('shardCount'), 0)]",
        "replicasPerPrimary": "[if(variables('isPremium'), parameters('replicasPerPrimary'), json('null'))]"
      }
    },
    {
      "copy": {
        "name": "firewallRuleCopy",
        "count": "[length(parameters('firewallRules'))]"
      },
      "type": "Microsoft.Cache/redis/firewallRules",
      "apiVersion": "2024-03-01",
      "name": "[concat(parameters('redisCacheName'), '/', parameters('firewallRules')[copyIndex()].name)]",
      "dependsOn": [
        "[resourceId('Microsoft.Cache/redis', parameters('redisCacheName'))]"
      ],
      "properties": {
        "startIP": "[parameters('firewallRules')[copyIndex()].startIP]",
        "endIP": "[parameters('firewallRules')[copyIndex()].endIP]"
      }
    }
  ],
  "outputs": {
    "cacheId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/redis', parameters('redisCacheName'))]"
    },
    "cacheHostName": {
      "type": "string",
      "value": "[reference(parameters('redisCacheName')).hostName]"
    },
    "cacheSslPort": {
      "type": "int",
      "value": "[reference(parameters('redisCacheName')).sslPort]"
    }
  }
}
