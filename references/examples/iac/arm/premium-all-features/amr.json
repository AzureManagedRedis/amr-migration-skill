{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_scenario": "Premium P2 all-features → AMR Balanced_B50 with everything",
    "_migratedFrom": "Premium P2 (13 GB) x 3 shards, MRPP, RDB, VNet, firewall",
    "_targetSkuInfo": "Balanced_B50 (comparable memory to P2 x 3 shards)",
    "_changes": [
      "Resource split: redis → redisEnterprise + databases + privateEndpoint + privateDnsZoneGroup",
      "SKU: Premium/P/2 x 3 shards → Balanced_B50",
      "Clustering: OSSCluster (source had shardCount=3, cluster-aware clients assumed)",
      "Eviction: volatile-lfu → VolatileLFU",
      "Persistence: rdb-backup-frequency 360 min → rdbFrequency 6h",
      "Persistence: storage connection + auth method removed (AMR manages internally)",
      "Networking: VNet injection → Private Endpoint",
      "Networking: Firewall rules removed (use NSG on PE subnet instead)",
      "DNS: privatelink.redis.azure.net",
      "Identity: preserved (type + userAssignedIdentities, not principalId/tenantId)",
      "Zones: REMOVED — AMR manages zone redundancy automatically",
      "Removed: shardCount, replicasPerPrimary, subnetId, staticIP, enableNonSslPort, redisVersion",
      "Removed: maxmemory-reserved, maxfragmentationmemory-reserved",
      "Preserved: publicNetworkAccess Disabled (carried from source)"
    ]
  },
  "resources": [
    {
      "type": "Microsoft.Cache/redisEnterprise",
      "apiVersion": "2025-07-01",
      "name": "my-enterprise-cache",
      "location": "westus2",
      "tags": {
        "Environment": "Production",
        "Service": "PlatformCore",
        "ManagedBy": "IaC",
        "CostCenter": "99999"
      },
      "identity": {
        "type": "SystemAssigned, UserAssigned",
        "userAssignedIdentities": {
          "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/my-rg/providers/Microsoft.ManagedIdentity/userAssignedIdentities/mi-persistence": {}
        }
      },
      "sku": {
        "name": "Balanced_B50"
      },
      "properties": {
        "minimumTlsVersion": "1.2",
        "publicNetworkAccess": "Disabled"
      }
    },
    {
      "type": "Microsoft.Cache/redisEnterprise/databases",
      "apiVersion": "2025-07-01",
      "name": "my-enterprise-cache/default",
      "dependsOn": [
        "[resourceId('Microsoft.Cache/redisEnterprise', 'my-enterprise-cache')]"
      ],
      "properties": {
        "clientProtocol": "Encrypted",
        "port": 10000,
        "evictionPolicy": "VolatileLFU",
        "clusteringPolicy": "OSSCluster",
        "persistence": {
          "rdbEnabled": true,
          "rdbFrequency": "6h"
        }
      }
    },
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "my-enterprise-cache-pe",
      "location": "westus2",
      "tags": {
        "Environment": "Production",
        "Service": "PlatformCore",
        "ManagedBy": "IaC",
        "CostCenter": "99999"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Cache/redisEnterprise', 'my-enterprise-cache')]"
      ],
      "properties": {
        "subnet": {
          "id": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/my-rg/providers/Microsoft.Network/virtualNetworks/my-vnet/subnets/pe-subnet"
        },
        "privateLinkServiceConnections": [
          {
            "name": "my-enterprise-cache-pe-conn",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Cache/redisEnterprise', 'my-enterprise-cache')]",
              "groupIds": [
                "redisEnterprise"
              ]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-11-01",
      "name": "my-enterprise-cache-pe/default",
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateEndpoints', 'my-enterprise-cache-pe')]"
      ],
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "privatelink-redis-azure-net",
            "properties": {
              "privateDnsZoneId": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/my-rg/providers/Microsoft.Network/privateDnsZones/privatelink.redis.azure.net"
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "cacheId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/redisEnterprise', 'my-enterprise-cache')]"
    },
    "hostName": {
      "type": "string",
      "value": "[concat('my-enterprise-cache', '.westus2.redis.azure.net')]"
    },
    "privateEndpointId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/privateEndpoints', 'my-enterprise-cache-pe')]"
    }
  }
}
