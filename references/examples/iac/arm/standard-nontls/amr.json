{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_scenario": "Standard C2 (non-TLS) → AMR Balanced_B3 with Plaintext protocol",
    "_migratedFrom": "Standard C2 (2.5 GB)",
    "_targetSkuInfo": "Balanced_B3 (comparable to Standard C2)",
    "_changes": [
      "Resource type: Microsoft.Cache/redis → Microsoft.Cache/redisEnterprise + databases",
      "SKU: Standard/C/2 → Balanced_B3",
      "Eviction: allkeys-lru → AllKeysLRU (PascalCase)",
      "Clustering: Non-clustered (omitted — source non-clustered, target ≤ 24GB)",
      "Port: 6379/6380 → 10000",
      "Protocol: enableNonSslPort true → clientProtocol Plaintext (preserves non-TLS access)",
      "Removed: enableNonSslPort, redisVersion, redisConfiguration",
      "Added: clientProtocol Plaintext, database resource",
      "Output: listKeys path updated from Microsoft.Cache/redis to Microsoft.Cache/redisEnterprise/databases"
    ]
  },
  "resources": [
    {
      "type": "Microsoft.Cache/redisEnterprise",
      "apiVersion": "2025-07-01",
      "name": "my-nontls-cache",
      "location": "eastus",
      "tags": {
        "Environment": "Development",
        "Service": "LegacyApp"
      },
      "sku": {
        "name": "Balanced_B3"
      },
      "properties": {
        "minimumTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Cache/redisEnterprise/databases",
      "apiVersion": "2025-07-01",
      "name": "my-nontls-cache/default",
      "dependsOn": [
        "[resourceId('Microsoft.Cache/redisEnterprise', 'my-nontls-cache')]"
      ],
      "properties": {
        "clientProtocol": "Plaintext",
        "port": 10000,
        "evictionPolicy": "AllKeysLRU"
      }
    }
  ],
  "outputs": {
    "cacheId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/redisEnterprise', 'my-nontls-cache')]"
    },
    "hostName": {
      "type": "string",
      "value": "[concat('my-nontls-cache', '.eastus.redis.azure.net')]"
    },
    "primaryAccessKey": {
      "type": "securestring",
      "value": "[listKeys(resourceId('Microsoft.Cache/redisEnterprise/databases', 'my-nontls-cache', 'default'), '2025-07-01').primaryKey]"
    }
  }
}
