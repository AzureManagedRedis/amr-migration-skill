{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_scenario": "Premium P2 with passive geo-replication (linkedServers) — tests geo-replication conversion",
    "_sourceSkuInfo": "Premium P2 (13 GB) x 3 shards with geo-replication"
  },
  "resources": [
    {
      "type": "Microsoft.Cache/redis",
      "apiVersion": "2024-03-01",
      "name": "my-geo-primary",
      "location": "westus2",
      "tags": {
        "Environment": "Production",
        "Service": "GlobalApp",
        "Role": "Primary"
      },
      "zones": [
        "1",
        "2",
        "3"
      ],
      "properties": {
        "sku": {
          "name": "Premium",
          "family": "P",
          "capacity": 2
        },
        "enableNonSslPort": false,
        "minimumTlsVersion": "1.2",
        "redisVersion": "6",
        "publicNetworkAccess": "Enabled",
        "shardCount": 3,
        "redisConfiguration": {
          "maxmemory-policy": "volatile-lru",
          "aad-enabled": "true",
          "maxmemory-reserved": "642",
          "maxfragmentationmemory-reserved": "642"
        }
      }
    },
    {
      "type": "Microsoft.Cache/redis/linkedServers",
      "apiVersion": "2024-03-01",
      "name": "my-geo-primary/my-geo-secondary",
      "dependsOn": [
        "[resourceId('Microsoft.Cache/redis', 'my-geo-primary')]"
      ],
      "properties": {
        "linkedRedisCacheId": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/my-rg-eastus/providers/Microsoft.Cache/redis/my-geo-secondary",
        "linkedRedisCacheLocation": "eastus",
        "serverRole": "Secondary"
      }
    }
  ],
  "outputs": {
    "cacheId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Cache/redis', 'my-geo-primary')]"
    },
    "hostName": {
      "type": "string",
      "value": "[reference('my-geo-primary').hostName]"
    }
  }
}
